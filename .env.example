# Copy to .env and edit. NEVER commit .env.

# --- Application ---
APP_NAME="Python Backend"
DEBUG=false

# --- Database ---
# Local dev (SQLite, no server needed):
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Docker Compose / production (Postgres via asyncpg):
# DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# --- Security ---
# Generate with: openssl rand -hex 32
# App refuses to start if this contains "replace-with" or "change-me".
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# JSON list of allowed origins. Must NOT be ["*"] when allow_credentials is true.
CORS_ORIGINS=["http://localhost:3000"]

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json     # "json" for prod, "console" for dev

# --- Postgres (used by docker-compose only) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
